{
  "manifest_version": 3,
  "name": "Trace AI Layer",
  "version": "1.0.0",
  "description": "Measure and reduce the environmental cost of your AI prompt usage.",
  "icons": {
    "128": "assets/trace-icon.svg"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "*://chat.openai.com/*",
        "*://chatgpt.com/*",
        "*://claude.ai/*",
        "*://gemini.google.com/*",
        "*://perplexity.ai/*",
        "*://chat.mistral.ai/*",
        "*://copilot.microsoft.com/*"
      ],
      "js": ["content.js"],
      "css": ["overlay.css"]
    },
    {
      "matches": [
        "http://localhost:3000/*",
        "http://localhost:3001/*"
      ],
      "js": ["dashboard-bridge.js"],
      "run_at": "document_idle"
    }
  ],
  "permissions": ["storage", "activeTab", "tabs", "downloads"],
  "host_permissions": [
    "https://generativelanguage.googleapis.com/*"
  ],
  "action": {
    "default_icon": {
      "128": "assets/trace-icon.svg"
    },
    "default_popup": "popup/popup.html",
    "default_title": "Trace AI Layer"
  },
  "web_accessible_resources": [
    {
      "resources": [
        "src/adapters/chatgpt.js",
        "src/adapters/claude.js",
        "src/adapters/gemini.js",
        "src/adapters/perplexity.js",
        "src/adapters/mistral.js",
        "src/adapters/copilot.js",
        "src/overlay/overlay.css"
      ],
      "matches": [
        "*://chat.openai.com/*",
        "*://chatgpt.com/*",
        "*://claude.ai/*",
        "*://gemini.google.com/*",
        "*://perplexity.ai/*",
        "*://chat.mistral.ai/*",
        "*://copilot.microsoft.com/*"
      ]
    }
  ]
}
