{
  "name": "trace-ai-layer",
  "version": "1.0.0",
  "description": "Chrome extension to measure and reduce the environmental cost of AI prompt usage.",
  "private": true,
  "scripts": {
    "build": "webpack --config webpack.config.js",
    "test": "jest --runInBand",
    "test:watch": "jest --watch"
  },
  "devDependencies": {
    "jest": "29.7.0",
    "jest-environment-jsdom": "29.7.0",
    "fast-check": "3.19.0",
    "webpack": "5.91.0",
    "webpack-cli": "5.1.4",
    "copy-webpack-plugin": "12.0.2",
    "babel-loader": "9.1.3",
    "@babel/core": "7.24.4",
    "@babel/preset-env": "7.24.4"
  },
  "dependencies": {
    "js-tiktoken": "1.0.15"
  },
  "jest": {
    "testEnvironment": "jsdom",
    "transform": {
      "^.+\\.js$": "babel-jest"
    },
    "transformIgnorePatterns": [],
    "testPathIgnorePatterns": [
      "/node_modules/",
      "/trace-dashboard/"
    ]
  }
}
